# ─── Admin Password ────────────────────────────────────────────────────────────
# Password for the /admin page. Change this before deploying.
ADMIN_PASSWORD=change-me-before-deploy

# ─── GitHub API (for Save & Deploy) ────────────────────────────────────────────
# 1. Go to: https://github.com/settings/tokens/new
# 2. Create a Fine-grained token with:
#    - Repository access: select your kidi-landing repo only
#    - Permissions: Contents (Read & Write)
# 3. Paste the token below
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# 4. Your GitHub repo in "owner/repo" format
GITHUB_REPO=your-username/kidi-landing

# 5. Branch to commit to (usually "main")
GITHUB_BRANCH=main

# ─── DigitalOcean App Platform ─────────────────────────────────────────────────
# Set these as environment variables in the DO App console.
# Build command: npm run build
# Run command: node server.js
# PORT is set automatically by DigitalOcean.
